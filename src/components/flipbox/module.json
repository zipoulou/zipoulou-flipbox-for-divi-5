{
  "name": "tangible/flipbox",
  "d4Shortcode": "",
  "title": "Zipoulou FlipBox",
  "titles": "Zipoulou FlipBoxes",
  "moduleIcon": "tangible/module-flipbox",
  "moduleClassName": "tmd5_flipbox",
  "moduleOrderClassName": "tmd5_flipbox",
  "category": "module",
  "attributes": {
    "flipbox": {
      "type": "object",
      "selector": "{{selector}}",
      "settings": {
        "innerContent": {
          "groupType": "group-items",
          "items": {
            "trigger": {
              "groupSlug": "contentFlipboxSettings",
              "attrName": "flipbox.innerContent",
              "subName": "trigger",
              "label": "Animation Trigger",
              "description": "How the flipbox reveals its back side: on hover, on click (toggle), or automatically on interval.",
              "features": { "hover": false, "sticky": false, "responsive": false },
              "render": true,
              "priority": 10,
              "component": {
                "type": "field",
                "name": "divi/select",
                "props": {
                  "options": {
                    "hover": { "label": "On Hover" },
                    "click": { "label": "On Click (toggle)" },
                    "auto":  { "label": "Automatic (interval)" }
                  }
                }
              }
            },
            "autoInterval": {
              "groupSlug": "contentFlipboxSettings",
              "attrName": "flipbox.innerContent",
              "subName": "autoInterval",
              "label": "Auto-Flip Interval",
              "description": "How long each side is shown before auto-flipping (seconds). Applies only when Trigger is Automatic.",
              "features": { "hover": false, "sticky": false, "responsive": false },
              "render": true,
              "priority": 35,
              "component": {
                "type": "field",
                "name": "divi/range",
                "props": {
                  "min": "1",
                  "max": "20",
                  "step": "1",
                  "default": "4",
                  "unitValue": true,
                  "validUnits": ["s"]
                }
              }
            },
            "type": {
              "groupSlug": "contentFlipboxSettings",
              "attrName": "flipbox.innerContent",
              "subName": "type",
              "label": "Animation Type",
              "description": "Animation style used to reveal the back side.",
              "features": { "hover": false, "sticky": false, "responsive": false },
              "render": true,
              "priority": 15,
              "component": {
                "type": "field",
                "name": "divi/select",
                "props": {
                  "options": {
                    "flip":    { "label": "3D Flip (uses Direction)" },
                    "slide":   { "label": "Slide (uses Direction)" },
                    "fade":    { "label": "Fade" },
                    "zoomIn":  { "label": "Zoom In" },
                    "zoomOut": { "label": "Zoom Out" },
                    "blur":    { "label": "Blur" }
                  }
                }
              }
            },
            "direction": {
              "groupSlug": "contentFlipboxSettings",
              "attrName": "flipbox.innerContent",
              "subName": "direction",
              "label": "Direction",
              "description": "Direction of movement (applies to 3D Flip and Slide only).",
              "features": { "hover": false, "sticky": false, "responsive": false },
              "render": true,
              "priority": 20,
              "component": {
                "type": "field",
                "name": "divi/select",
                "props": {
                  "options": {
                    "right": { "label": "Right" },
                    "left":  { "label": "Left" },
                    "up":    { "label": "Up" },
                    "down":  { "label": "Down" }
                  }
                }
              }
            },
            "duration": {
              "groupSlug": "contentFlipboxSettings",
              "attrName": "flipbox.innerContent",
              "subName": "duration",
              "label": "Animation Duration (ms)",
              "description": "Duration of the flip animation in milliseconds.",
              "features": { "hover": false, "sticky": false, "responsive": false },
              "render": true,
              "priority": 30,
              "component": {
                "type": "field",
                "name": "divi/range",
                "props": {
                  "min": "100",
                  "max": "2000",
                  "step": "50",
                  "default": "600",
                  "unitValue": true,
                  "validUnits": ["ms"]
                }
              }
            },
            "layout": {
              "groupSlug": "contentFlipboxSettings",
              "attrName": "flipbox.innerContent",
              "subName": "layout",
              "label": "Layout Mode",
              "description": "Front-side layout. 'Image Cover' uses the image as full background with text overlay.",
              "features": { "hover": false, "sticky": false, "responsive": true },
              "render": true,
              "priority": 5,
              "component": {
                "type": "field",
                "name": "divi/select",
                "props": {
                  "options": {
                    "content":    { "label": "Icon/Image + Text" },
                    "textOnly":   { "label": "Text Only" },
                    "mediaOnly":  { "label": "Media Only" },
                    "imageCover": { "label": "Image Cover (background)" }
                  }
                }
              }
            },
            "sizeMode": {
              "groupSlug": "contentFlipboxSettings",
              "attrName": "flipbox.innerContent",
              "subName": "sizeMode",
              "label": "Size Mode",
              "description": "How the tile height is determined. Aspect ratio keeps grid consistency.",
              "features": { "hover": false, "sticky": false, "responsive": true },
              "render": true,
              "priority": 40,
              "component": {
                "type": "field",
                "name": "divi/select",
                "props": {
                  "options": {
                    "minHeight": { "label": "Minimum Height" },
                    "aspect":    { "label": "Aspect Ratio" },
                    "fixed":     { "label": "Fixed Height" }
                  }
                }
              }
            },
            "aspectRatio": {
              "groupSlug": "contentFlipboxSettings",
              "attrName": "flipbox.innerContent",
              "subName": "aspectRatio",
              "label": "Aspect Ratio",
              "description": "Width:Height ratio — only applies when Size Mode is Aspect Ratio.",
              "features": { "hover": false, "sticky": false, "responsive": true },
              "render": true,
              "priority": 50,
              "component": {
                "type": "field",
                "name": "divi/select",
                "props": {
                  "options": {
                    "1/1":  { "label": "1 : 1 (Square)" },
                    "4/3":  { "label": "4 : 3" },
                    "3/2":  { "label": "3 : 2" },
                    "16/9": { "label": "16 : 9 (Widescreen)" },
                    "2/1":  { "label": "2 : 1" }
                  }
                }
              }
            },
            "minHeight": {
              "groupSlug": "contentFlipboxSettings",
              "attrName": "flipbox.innerContent",
              "subName": "minHeight",
              "label": "Minimum Height",
              "description": "Tile minimum height — only applies when Size Mode is Minimum Height.",
              "features": { "hover": false, "sticky": false, "responsive": true },
              "render": true,
              "priority": 60,
              "component": {
                "type": "field",
                "name": "divi/range",
                "props": {
                  "min": "100",
                  "max": "800",
                  "step": "10",
                  "default": "320",
                  "unitValue": true,
                  "validUnits": ["px"]
                }
              }
            },
            "fixedHeight": {
              "groupSlug": "contentFlipboxSettings",
              "attrName": "flipbox.innerContent",
              "subName": "fixedHeight",
              "label": "Fixed Height",
              "description": "Tile exact height — only applies when Size Mode is Fixed Height.",
              "features": { "hover": false, "sticky": false, "responsive": true },
              "render": true,
              "priority": 70,
              "component": {
                "type": "field",
                "name": "divi/range",
                "props": {
                  "min": "100",
                  "max": "800",
                  "step": "10",
                  "default": "320",
                  "unitValue": true,
                  "validUnits": ["px"]
                }
              }
            }
          }
        }
      }
    },

    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "styleProps": { "border": { "important": true } },
      "settings": {
        "meta": { "adminLabel": {} },
        "advanced": {
          "link": {},
          "text": {},
          "htmlAttributes": {}
        },
        "decoration": {
          "attributes": {},
          "background": {},
          "sizing": {},
          "spacing": {},
          "border": {},
          "boxShadow": {},
          "filters": {},
          "transform": {},
          "animation": {},
          "overflow": {},
          "disabledOn": {},
          "transition": {},
          "position": {},
          "zIndex": {},
          "scroll": {},
          "sticky": {}
        }
      }
    },

    "frontMedia": {
      "type": "object",
      "selector": "{{selector}} .tmd5_flipbox__front-media .et-pb-icon, {{selector}} .tmd5_flipbox__front-media img",
      "supportsCustomAttributes": true,
      "settings": {
        "innerContent": {
          "groupType": "group-items",
          "items": {
            "useIcon": {
              "groupSlug": "contentFrontMedia",
              "attrName": "frontMedia.innerContent",
              "subName": "useIcon",
              "label": "Use Icon",
              "description": "Toggle to use an icon instead of an image on the front side.",
              "features": { "hover": false, "sticky": false, "responsive": false },
              "render": true,
              "priority": 10,
              "component": { "type": "field", "name": "divi/toggle" }
            },
            "icon": {
              "groupSlug": "contentFrontMedia",
              "attrName": "frontMedia.innerContent",
              "subName": "icon",
              "label": "Icon",
              "description": "Choose an icon to display on the front side.",
              "features": { "sticky": false },
              "render": true,
              "priority": 20,
              "component": { "type": "field", "name": "divi/icon-picker" }
            },
            "src": {
              "groupSlug": "contentFrontMedia",
              "attrName": "frontMedia.innerContent",
              "subName": "src",
              "label": "Image",
              "description": "Upload an image to display on the front side.",
              "features": { "sticky": false, "hover": true, "responsive": true },
              "render": true,
              "priority": 30,
              "component": {
                "type": "field",
                "name": "divi/upload",
                "props": {
                  "syncImageData": { "src": true, "id": true, "alt": true, "titleText": true }
                }
              }
            }
          }
        },
        "advanced": {
          "color": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "designFrontMedia",
              "attrName": "frontMedia.advanced.color",
              "label": "Icon Color",
              "description": "Custom color for the front icon.",
              "render": true,
              "priority": 10,
              "component": { "type": "field", "name": "divi/color-picker" }
            }
          },
          "fit": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "designFrontMedia",
              "attrName": "frontMedia.advanced.fit",
              "label": "Image Fit",
              "description": "How the image fills the media zone. Cover fills + crops, contain fits inside.",
              "features": { "hover": false, "sticky": false, "responsive": true },
              "render": true,
              "priority": 20,
              "component": {
                "type": "field",
                "name": "divi/select",
                "props": {
                  "options": {
                    "cover":   { "label": "Cover (fill & crop)" },
                    "contain": { "label": "Contain (fit inside)" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "frontSubtitle": {
      "type": "object",
      "selector": "{{selector}} .tmd5_flipbox__front-subtitle",
      "tagName": "h4",
      "attributes": { "class": "tmd5_flipbox__front-subtitle" },
      "inlineEditor": "plainText",
      "elementType": "heading",
      "childrenSanitizer": "et_core_esc_previously",
      "styleProps": {
        "font": { "important": { "font": { "desktop": { "value": { "color": true } } } } }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentFront",
            "priority": 5,
            "render": true,
            "attrName": "frontSubtitle.innerContent",
            "label": "Front Subtitle",
            "description": "Subtitle shown above the front title.",
            "features": { "sticky": false, "dynamicContent": false },
            "component": { "name": "divi/text", "type": "field" }
          }
        },
        "decoration": {
          "font": {
            "priority": 12,
            "component": {
              "props": {
                "groupLabel": "Front Subtitle Text",
                "fieldLabel": "Front Subtitle"
              }
            }
          }
        }
      }
    },

    "frontTitle": {
      "type": "object",
      "selector": "{{selector}} .tmd5_flipbox__front-title",
      "styleProps": {
        "font": { "important": { "font": { "desktop": { "value": { "color": true } } } } }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentFront",
            "priority": 10,
            "render": true,
            "attrName": "frontTitle.innerContent",
            "label": "Front Title",
            "description": "Title displayed on the front side of the flipbox.",
            "features": { "sticky": false, "dynamicContent": false },
            "component": { "name": "divi/text", "type": "field" }
          }
        },
        "decoration": {
          "font": {
            "priority": 10,
            "component": {
              "props": { "groupLabel": "Front Title Text", "fieldLabel": "Front Title" }
            }
          }
        }
      },
      "tagName": "h3",
      "attributes": { "class": "tmd5_flipbox__front-title" },
      "inlineEditor": "plainText",
      "elementType": "heading",
      "childrenSanitizer": "et_core_esc_previously"
    },

    "frontContent": {
      "type": "object",
      "selector": "{{selector}} .tmd5_flipbox__front-content",
      "tagName": "div",
      "attributes": { "class": "tmd5_flipbox__front-content" },
      "inlineEditor": "richText",
      "childrenSanitizer": "et_core_esc_previously",
      "styleProps": {
        "bodyFont": {
          "selectors": { "desktop": { "value": "{{selector}} .tmd5_flipbox__front-content" } }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentFront",
            "priority": 20,
            "render": true,
            "attrName": "frontContent.innerContent",
            "label": "Front Content",
            "description": "Body text displayed on the front side.",
            "features": { "sticky": false, "dynamicContent": false },
            "component": { "name": "divi/richtext", "type": "field" }
          }
        },
        "decoration": { "bodyFont": {} }
      }
    },

    "backSubtitle": {
      "type": "object",
      "selector": "{{selector}} .tmd5_flipbox__back-subtitle",
      "tagName": "h4",
      "attributes": { "class": "tmd5_flipbox__back-subtitle" },
      "inlineEditor": "plainText",
      "elementType": "heading",
      "childrenSanitizer": "et_core_esc_previously",
      "styleProps": {
        "font": { "important": { "font": { "desktop": { "value": { "color": true } } } } }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentBack",
            "priority": 5,
            "render": true,
            "attrName": "backSubtitle.innerContent",
            "label": "Back Subtitle",
            "description": "Subtitle shown above the back title.",
            "features": { "sticky": false, "dynamicContent": false },
            "component": { "name": "divi/text", "type": "field" }
          }
        },
        "decoration": {
          "font": {
            "priority": 12,
            "component": {
              "props": { "groupLabel": "Back Subtitle Text", "fieldLabel": "Back Subtitle" }
            }
          }
        }
      }
    },

    "backTitle": {
      "type": "object",
      "selector": "{{selector}} .tmd5_flipbox__back-title",
      "styleProps": {
        "font": { "important": { "font": { "desktop": { "value": { "color": true } } } } }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentBack",
            "priority": 10,
            "render": true,
            "attrName": "backTitle.innerContent",
            "label": "Back Title",
            "description": "Title displayed on the back (flipped) side.",
            "features": { "sticky": false, "dynamicContent": false },
            "component": { "name": "divi/text", "type": "field" }
          }
        },
        "decoration": {
          "font": {
            "priority": 10,
            "component": {
              "props": { "groupLabel": "Back Title Text", "fieldLabel": "Back Title" }
            }
          }
        }
      },
      "tagName": "h3",
      "attributes": { "class": "tmd5_flipbox__back-title" },
      "inlineEditor": "plainText",
      "elementType": "heading",
      "childrenSanitizer": "et_core_esc_previously"
    },

    "backContent": {
      "type": "object",
      "selector": "{{selector}} .tmd5_flipbox__back-content",
      "tagName": "div",
      "attributes": { "class": "tmd5_flipbox__back-content" },
      "inlineEditor": "richText",
      "childrenSanitizer": "et_core_esc_previously",
      "styleProps": {
        "bodyFont": {
          "selectors": { "desktop": { "value": "{{selector}} .tmd5_flipbox__back-content" } }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentBack",
            "priority": 20,
            "render": true,
            "attrName": "backContent.innerContent",
            "label": "Back Content",
            "description": "Body text displayed on the back side.",
            "features": { "sticky": false, "dynamicContent": false },
            "component": { "name": "divi/richtext", "type": "field" }
          }
        },
        "decoration": { "bodyFont": {} }
      }
    },

    "backButton": {
      "type": "object",
      "selector": "{{selector}} .tmd5_flipbox__back-button",
      "tagName": "a",
      "attributes": { "class": "tmd5_flipbox__back-button" },
      "styleProps": {
        "font": { "important": { "font": { "desktop": { "value": { "color": true } } } } }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-items",
          "items": {
            "text": {
              "groupSlug": "contentBackButton",
              "attrName": "backButton.innerContent",
              "subName": "text",
              "label": "Button Text",
              "description": "Text of the call-to-action button on the back side.",
              "features": { "sticky": false, "dynamicContent": false },
              "render": true,
              "priority": 10,
              "component": { "type": "field", "name": "divi/text" }
            },
            "url": {
              "groupSlug": "contentBackButton",
              "attrName": "backButton.innerContent",
              "subName": "url",
              "label": "Button URL",
              "description": "Destination URL when the button is clicked.",
              "features": { "sticky": false, "hover": false, "responsive": false },
              "render": true,
              "priority": 20,
              "component": { "type": "field", "name": "divi/text" }
            },
            "target": {
              "groupSlug": "contentBackButton",
              "attrName": "backButton.innerContent",
              "subName": "target",
              "label": "Open in New Tab",
              "description": "Open the button link in a new browser tab.",
              "features": { "sticky": false, "hover": false, "responsive": false },
              "render": true,
              "priority": 30,
              "component": { "type": "field", "name": "divi/toggle" }
            }
          }
        },
        "decoration": {
          "background": {},
          "border": {},
          "boxShadow": {},
          "spacing": {},
          "font": {
            "component": {
              "props": { "groupLabel": "Back Button Text", "fieldLabel": "Back Button" }
            }
          }
        }
      }
    }
  },
  "customCssFields": {
    "inner":         { "subName": "inner",         "selectorSuffix": " .tmd5_flipbox__inner" },
    "front":         { "subName": "front",         "selectorSuffix": " .tmd5_flipbox__front" },
    "back":          { "subName": "back",          "selectorSuffix": " .tmd5_flipbox__back" },
    "frontMedia":    { "subName": "frontMedia",    "selectorSuffix": " .tmd5_flipbox__front-media" },
    "frontSubtitle": { "subName": "frontSubtitle", "selectorSuffix": " .tmd5_flipbox__front-subtitle" },
    "frontTitle":    { "subName": "frontTitle",    "selectorSuffix": " .tmd5_flipbox__front-title" },
    "frontContent":  { "subName": "frontContent",  "selectorSuffix": " .tmd5_flipbox__front-content" },
    "backSubtitle":  { "subName": "backSubtitle",  "selectorSuffix": " .tmd5_flipbox__back-subtitle" },
    "backTitle":     { "subName": "backTitle",     "selectorSuffix": " .tmd5_flipbox__back-title" },
    "backContent":   { "subName": "backContent",   "selectorSuffix": " .tmd5_flipbox__back-content" },
    "backButton":    { "subName": "backButton",    "selectorSuffix": " .tmd5_flipbox__back-button" }
  },
  "settings": {
    "content": "auto",
    "design": "auto",
    "advanced": "auto",
    "groups": {
      "contentFlipboxSettings": {
        "panel": "content",
        "priority": 1,
        "groupName": "contentFlipboxSettings",
        "multiElements": true,
        "component": {
          "name": "divi/composite",
          "props": { "groupLabel": "Flipbox Settings" }
        }
      },
      "contentFrontMedia": {
        "panel": "content",
        "priority": 5,
        "groupName": "contentFrontMedia",
        "multiElements": true,
        "component": {
          "name": "divi/composite",
          "props": { "groupLabel": "Front Icon / Image" }
        }
      },
      "contentFront": {
        "panel": "content",
        "priority": 10,
        "groupName": "contentFront",
        "multiElements": true,
        "component": {
          "name": "divi/composite",
          "props": { "groupLabel": "Front Side" }
        }
      },
      "contentBack": {
        "panel": "content",
        "priority": 20,
        "groupName": "contentBack",
        "multiElements": true,
        "component": {
          "name": "divi/composite",
          "props": { "groupLabel": "Back Side" }
        }
      },
      "contentBackButton": {
        "panel": "content",
        "priority": 30,
        "groupName": "contentBackButton",
        "multiElements": true,
        "component": {
          "name": "divi/composite",
          "props": { "groupLabel": "Back Button" }
        }
      },
      "designFrontMedia": {
        "panel": "design",
        "priority": 5,
        "groupName": "designFrontMedia",
        "multiElements": true,
        "component": {
          "name": "divi/composite",
          "props": { "groupLabel": "Front Icon / Image Style" }
        }
      }
    }
  }
}
